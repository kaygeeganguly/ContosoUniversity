            },
            "containerAppName": {
              "type": "string",
              "value": "[format('azca{0}', parameters('resourceToken'))]"
            },
            "containerAppId": {
              "type": "string",
              "value": "[resourceId('Microsoft.App/containerApps', format('azca{0}', parameters('resourceToken')))]"
            },
            "containerAppEnvName": {
