@{
    ViewBag.Title = "Admin Notifications";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <h2>@ViewBag.Title</h2>
        <p class="text-muted">Real-time notifications for entity operations across the system.</p>
        
        <div class="alert alert-info" role="alert">
            <strong>Real-time Notifications</strong><br />
            As an administrator, you will receive notifications in the top-right corner when any entity (students, courses, instructors, departments) is created, updated, or deleted by any user in the system.
        </div>
        
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Notification Settings</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h4>Monitored Operations</h4>
                        <ul class="list-group">
                            <li class="list-group-item"><span class="badge bg-success">CREATE</span> Entity creation operations</li>
                            <li class="list-group-item"><span class="badge bg-info">UPDATE</span> Entity modification operations</li>
                            <li class="list-group-item"><span class="badge bg-warning">DELETE</span> Entity deletion operations</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h4>Monitored Entities</h4>
                        <ul class="list-group">
                            <li class="list-group-item">Students</li>
                            <li class="list-group-item">Courses</li>
                            <li class="list-group-item">Instructors</li>
                            <li class="list-group-item">Departments</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h3 class="card-title">Technology Information</h3>
            </div>
            <div class="card-body">
                <div class="alert alert-warning" role="alert">
                    <strong>Note:</strong> This notification system uses an in-memory queue for message delivery.
                </div>

                <h4>Features:</h4>
                <ul>
                    <li><strong>Real-time delivery</strong> - Notifications appear immediately when operations occur</li>
                    <li><strong>Auto-dismiss</strong> - Notifications automatically disappear after 8 seconds</li>
                    <li><strong>User-friendly</strong> - Click the × to dismiss notifications manually</li>
                </ul>

                <h4>Queue Information:</h4>
                <p><strong>Queue Type:</strong> In-memory concurrent queue</p>
                <p><strong>Check Interval:</strong> 5 seconds</p>
                <p><strong>Max Visible Notifications:</strong> 5 at a time</p>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-body">
                <h4>Quick Test</h4>
                <p>To test the notification system, try performing any of the following operations:</p>
                <ul>
                    <li><a class="btn btn-sm btn-primary" asp-controller="Students" asp-action="Create">Create a new student</a></li>
                    <li><a class="btn btn-sm btn-success" asp-controller="Courses" asp-action="Create">Create a new course</a></li>
                    <li><a class="btn btn-sm btn-warning" asp-controller="Instructors" asp-action="Create">Create a new instructor</a></li>
                    <li><a class="btn btn-sm btn-info" asp-controller="Departments" asp-action="Create">Create a new department</a></li>
                </ul>
                <p class="text-muted">After creating, editing, or deleting any entity, you should see a notification appear in the top-right corner of your screen.</p>
            </div>
        </div>
    </div>
</div>
