@model IEnumerable<ContosoUniversity.Models.Course>

@{
    ViewBag.Title = "Courses";
}

<h2>Courses</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New</a>
</p>

<table class="table">
    <tr>
        <th>Course ID</th>
        <th>Title</th>
        <th>Credits</th>
        <th>Department</th>
        <th>Teaching Material</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CourseID</td>
            <td>@item.Title</td>
            <td>@item.Credits</td>
            <td>@item.Department?.Name</td>
            <td>
                @if (!string.IsNullOrEmpty(item.TeachingMaterialImagePath))
                {
                    <img src="@item.TeachingMaterialImagePath" alt="Teaching Material" style="max-width: 50px; max-height: 50px; border: 1px solid #ddd;" />
                }
                else
                {
                    <em>No image</em>
                }
            </td>
            <td>
                <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.CourseID">Details</a>
                |
                <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.CourseID">Edit</a>
                |
                <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.CourseID">Delete</a>
            </td>
        </tr>
    }
</table>
