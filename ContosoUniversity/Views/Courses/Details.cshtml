@model ContosoUniversity.Models.Course

@{
    ViewBag.Title = "Details";
}

<h2>Details</h2>

<div>
    <h4>Course</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Course ID</dt>
        <dd>@Model.CourseID</dd>
        <dt>Title</dt>
        <dd>@Model.Title</dd>
        <dt>Credits</dt>
        <dd>@Model.Credits</dd>
        <dt>Department</dt>
        <dd>@Model.Department?.Name</dd>
        <dt>Teaching Material</dt>
        <dd>
            @if (!string.IsNullOrEmpty(Model.TeachingMaterialImagePath))
            {
                <img src="@Model.TeachingMaterialImagePath" alt="Teaching Material" style="max-width: 300px; max-height: 300px; border: 1px solid #ddd; padding: 5px;" />
            }
            else
            {
                <em>No image uploaded</em>
            }
        </dd>
    </dl>
</div>
<p>
    <a asp-action="Edit" asp-route-id="@Model.CourseID">Edit</a> |
    <a asp-action="Index">Back to List</a>
</p>
